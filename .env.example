# Core
LINEAR_API_KEY=your_linear_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
LINEAR_READY_LABEL=agent-ready
LINEAR_MAX_ISSUES=5
LOG_LEVEL=INFO

# Development Agent
LINEAR_TEAM_ID=your_linear_team_id_here
PROJECT_PATH=/path/to/your/project
DEV_AGENT_BACKEND=claude

# Claude Code CLI
CLAUDE_CODE_COMMAND=claude
CLAUDE_ALLOWED_TOOLS=Read,Edit,Bash
CLAUDE_TIMEOUT_SECONDS=3600

# Codex (reserved for future use)
CODEX_COMMAND=codex
CODEX_TIMEOUT_SECONDS=3600
CODEX_ARGS=

# Flow labels (change only if you renamed labels in Linear)
FLOW_LABEL_DEV=agent-dev
FLOW_LABEL_TEST=agent-test
FLOW_LABEL_REVIEW=agent-review
FLOW_LABEL_ESCALATE=agent-escalate
FLOW_LABEL_HUMAN_CONFIRM=human-confirm
FLOW_LABEL_HUMAN_FAILED=human-failed
DEVELOPMENT_NEXT_LABEL=agent-review
